6.16 PRACTICE: Arrays**: Min, max, average

import java.util.Scanner;

public class Main {
   public static void main(String[] args) {
      Scanner scnr = new Scanner(System.in);
      
      int[] userValues = new int[10];
      int i;
      
      int firstValue = scnr.nextInt();

        userValues[0] = firstValue;

        int minVal = firstValue;

        int maxVal = firstValue;

        int sumVals = firstValue;

        for (i = 1; i < 10; ++i) {

            userValues[i] = scnr.nextInt();

            if (userValues[i] < minVal) {

                minVal = userValues[i];

            }

            if (userValues[i] > maxVal) {

                maxVal = userValues[i];

            }

            sumVals += userValues[i];

        }

        double average = (double) sumVals / 10.0;

        System.out.println(minVal + " " + maxVal + " " + average);

           
      
      
   }
}
